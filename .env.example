# Sanity — copy to .env.local and fill in values. Never commit real tokens.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
SANITY_API_READ_TOKEN=
# Editor/Admin token — local scripts only (e.g. seed-technologies.mjs). Never expose in the browser.
SANITY_API_WRITE_TOKEN=
# Deploy token — for `npm run sanity:deploy:hosted` only. Create at sanity.io/manage → API → Tokens → Deploy Studio.
SANITY_AUTH_TOKEN=
